use smart_planner;
show tables;
CREATE TABLE developers (
    dev_id INT PRIMARY KEY,
    name VARCHAR(100),
    experience_level VARCHAR(20), 
    primary_skill VARCHAR(50),
    current_load INT DEFAULT 0,
);
CREATE TABLE sprint_context (
    sprint_id INT PRIMARY KEY,
    team_load_percentage INT,     
    is_holiday_season BOOLEAN     
);
CREATE TABLE historical_tasks (
    task_id INT PRIMARY KEY,
    dev_id INT,
    sprint_id INT,
    category VARCHAR(50),
    story_points INT,
    actual_hours FLOAT,
    -- These keys ensure you can't have a task without a real developer
    FOREIGN KEY (dev_id) REFERENCES developers(dev_id),
    FOREIGN KEY (sprint_id) REFERENCES sprint_context(sprint_id)
);

ALTER TABLE developers
ADD COLUMN current_load INT DEFAULT 0;

DESCRIBE developers;